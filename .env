# FaceNet / face verification
MODEL_PATH=models/facenet_labersa_cpu.pt
IMAGE_SIZE=160
SIMILARITY_THRESHOLD=0.75
FINAL_SCORE_THRESHOLD=0.80
FACE_API_KEY=labersa-internal-api-key-2026
PORT=8001
DEVICE=cpu

# Anti-spoofing baru: HF ensemble
ANTI_SPOOFING_ENABLED=1
# Default jika folder repo HF diletakkan di dalam project: ./face-anti-spoofing_hf
# Windows contoh:
# HF_REPO_DIR=D:\Dataset_Spoof\face-anti-spoofing_hf
HF_REPO_DIR=face-anti-spoofing_hf
HF_ANTISPOOF_CONFIG_PATH=api_settings.json

# Threshold tambahan untuk real_score. Default 0 = ikuti keputusan ensemble.
ANTI_SPOOF_REAL_THRESHOLD=0.0

# Threshold per model = threshold untuk spoof_prob.
HF_THR_SASF=0.70
HF_THR_FLRGB=0.45
HF_THR_ICM2O=0.564862
HF_THR_IOM2C=0.218523
HF_THR_CDCN=0.53

# Bobot ensemble. Jika CDCN++ tidak tersedia, bobot model aktif dinormalisasi otomatis.
HF_W_SASF=0.20
HF_W_FLRGB=0.20
HF_W_ICM2O=0.20
HF_W_IOM2C=0.20
HF_W_CDCN=0.20

# Validasi tambahan lama
FACE_DET_MIN_PROB=0.90
FACE_CROP_MARGIN=0.15
SCREEN_SPOOF_ENABLED=1
LIVENESS_ENABLED=1
